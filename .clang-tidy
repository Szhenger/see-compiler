---
# .clang-tidy
# Static analysis and linting rules for the SeeC++ Compiler

# 1. Check Suites
# We start by disabling all checks (-*), then opt-in to specific suites tailored 
# for high-performance C++20 and the Google C++ Style Guide.
Checks: >
  -*,
  bugprone-*,
  cppcoreguidelines-*,
  google-*,
  misc-*,
  modernize-*,
  performance-*,
  readability-*,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-type-reinterpret-cast,
  -modernize-use-trailing-return-type,
  -readability-magic-numbers

# 2. Warnings as Errors
# During CI, we want all enabled tidy checks to fail the build.
WarningsAsErrors: '*'

# 3. Header Filtering
# CRITICAL: We only want to lint OUR code. This regex ensures Clang-Tidy 
# ignores everything inside external/ (like ONNX and GoogleTest) which 
# would otherwise throw thousands of warnings out of our control.
HeaderFilterRegex: '^.*/include/seecpp/.*|^.*/src/.*'

# 4. Format Integration
# Tells Clang-Tidy to respect the .clang-format rules when applying automatic fixes.
FormatStyle: 'file'

# 5. Check-Specific Options
CheckOptions:
  # Enforce standard initialization (avoiding uninitialized memory in tensors)
  - key:             cppcoreguidelines-init-variables.IncludeStyle
    value:           'google'
  
  # Google style requires namespaces to end with a comment: // namespace xyz
  - key:             google-readability-namespace-comments.SpacesBeforeComments
    value:           2
    
  # Catch implicit string allocations in loops
  - key:             performance-inefficient-string-concatenation.StrictMode
    value:           true
