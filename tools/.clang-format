# .clang-format
# Enforces Google C++ Style Guide for the SeeC++ Compiler

BasedOnStyle: Google
Language: Cpp
Standard: c++20

# --- Core Formatting ---
# Google strictly adheres to an 80-character limit to enforce concise statements
# and allow side-by-side file comparisons during pull request reviews.
ColumnLimit: 80
IndentWidth: 2
TabWidth: 2
UseTab: Never

# --- Pointers & References ---
# Google style mandates attaching the asterisk/ampersand to the type, not the variable.
# Example: `TensorNode* node;` instead of `TensorNode *node;`
DerivePointerAlignment: false
PointerAlignment: Left

# --- Header Include Management ---
# This is critical for our architecture. It automatically groups and alphabetically 
# sorts your #includes to prevent cyclic dependencies and path collisions.
SortIncludes: true
IncludeBlocks: Regroup
IncludeCategories:
  # 1. C/C++ System Headers (e.g., <vector>, <memory>)
  - Regex:           '^<.*>'
    Priority:        1
  # 2. SeeC++ Public API (e.g., <seecpp/compiler.h>)
  - Regex:           '^<seecpp/.*>'
    Priority:        2
  # 3. External Vendor Libraries (e.g., "onnx/onnx.pb.h", "gtest/gtest.h")
  - Regex:           '^".*"'
    Priority:        3

# --- Code Blocks & Inlining ---
# Allow simple getters/setters in the AST nodes to live on a single line
# to reduce vertical bloat in the Frontend graph definitions.
AllowShortFunctionsOnASingleLine: Inline
AllowShortBlocksOnASingleLine: Never
AllowShortIfStatementsOnASingleLine: WithoutElse
AllowShortLoopsOnASingleLine: false

# --- Namespaces ---
# Automatically appends `// namespace name` at the closing brace of a namespace.
# Crucial for heavily nested compiler passes.
FixNamespaceComments: true
CompactNamespaces: false

# --- Object Oriented Modifiers ---
# Indents `public:` and `private:` back by one space from the class definition.
AccessModifierOffset: -1

# --- Macros ---
# Specifically for GoogleTest and standard C++ boilerplate
IndentMacros: false
